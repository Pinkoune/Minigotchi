rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // One save document per user, at saves/{uid}. A signed-in user may only
    // ever read or write their own document — the same isolation guarantee
    // the old backend enforced by deriving user_id from the session token.
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
