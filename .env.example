# Extension build-time configuration (Vite). Copy to .env — never commit .env.
# None of these are secret in the "must stay hidden" sense (they end up in
# the built extension either way), but keep them out of source control so
# different builds can target different Firebase/OAuth projects.

# The extension ID is pinned by the manifest key: the OAuth redirect URI is
# ALWAYS https://hohchkjjnffpcalkfkljcjhddgdfhdlc.chromiumapp.org/
# (paste it as-is wherever a setup step asks for a redirect URI).

# OAuth client IDs (public identifiers, PKCE flow — no secrets in the extension)
# Google: Firebase console > Authentication > Sign-in method > Google >
# "Web SDK configuration" shows the auto-created Web client ID. Reuse it here,
# and add the redirect URI above to that client in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Microsoft is OPTIONAL: leave empty to hide the button entirely.
# Azure AD > App registrations > your app (platform "Single-page application")
VITE_MICROSOFT_CLIENT_ID=

# Firebase web config (Firebase Console > Project settings > General > Your apps)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
