# Extension build-time configuration (Vite). Copy to .env — never commit .env.

# Backend API origin (used for host_permissions and the sync client)
VITE_API_URL=http://localhost:8000

# OAuth client IDs (public identifiers, PKCE flow — no secrets in the extension)
# Google Cloud Console > Credentials > OAuth client (type "Web application")
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Azure AD > App registrations > your app (platform "Single-page application")
VITE_MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
